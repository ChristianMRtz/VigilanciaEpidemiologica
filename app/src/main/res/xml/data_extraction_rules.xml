<?xml version="1.0" encoding="utf-8"?>
<!--
    Reglas de Auto Backup para Android 12+.
    Incluye los tres archivos de la BD Room (main + WAL).
    Google Drive guarda la copia automáticamente.
    Al reinstalar la app con la misma cuenta de Google, se restaura todo.
-->
<data-extraction-rules>
    <!-- Backup a Google Drive (dispositivo perdido/roto) -->
    <cloud-backup>
        <include domain="database" path="vigilancia_epidemiologica.db"/>
        <include domain="database" path="vigilancia_epidemiologica.db-shm"/>
        <include domain="database" path="vigilancia_epidemiologica.db-wal"/>
    </cloud-backup>
    <!-- Transferencia entre dispositivos (ej: tablet nueva) -->
    <device-transfer>
        <include domain="database" path="vigilancia_epidemiologica.db"/>
        <include domain="database" path="vigilancia_epidemiologica.db-shm"/>
        <include domain="database" path="vigilancia_epidemiologica.db-wal"/>
    </device-transfer>
</data-extraction-rules>